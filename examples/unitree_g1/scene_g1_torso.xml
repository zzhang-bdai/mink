      <geom type="box" size=".08 .08 .15" contype="0" conaffinity="0" rgba=".6 .3 .3 .25"/>
      <site type="sphere" size="0.015" rgba="0 0 1 1" group="1"/>
    </body>
  </worldbody>

  <keyframe>
    <key name="stand_drag"
      qpos="
      0 0 0.8
      1 0 0 0
      -0.1 0 0 0.3 -0.2 0
      -0.1 0 0 0.3 -0.2 0
      0 0 0
      0.35 0.18 0 0.87 0 0 0
      0.35 -0.18 0 0.87 0 0 0
      "/>
  </keyframe>
